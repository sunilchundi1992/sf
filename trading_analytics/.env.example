# ====================================================================
# Trading Analytics Platform - Environment Configuration
# Copy this file to ".env" and fill in your real values.
# ====================================================================

# --- Upstox API ---
# Absolute path to the file containing your Upstox access token (single line).
UPSTOX_TOKEN_FILE=C:\Users\VEKSHA\Documents\Trading\Python codes\UPSTOX_FINAL\access_token.txt

# Underlying index instrument key (as used by Upstox).
INSTRUMENT_KEY=NSE_INDEX|Nifty 50

# Instrument key used for intraday CANDLES (the tradable future/index series).
# In your maxpain script this was the FO key, e.g. NSE_FO|62329
CANDLE_INSTRUMENT_KEY=NSE_FO|62329

# Active option-chain expiry (YYYY-MM-DD).
EXPIRY_DATE=2026-06-30

# Candle / bucket interval in minutes.
INTERVAL_MINUTES=3

# Strike range filter for the option chain (OI walls).
STRIKE_LOWER=21000
STRIKE_UPPER=27000

# --- Scheduler ---
# How often (seconds) to poll Upstox and append to the DB.
POLL_INTERVAL_SECONDS=180

# Run the poller automatically on startup (true/false).
ENABLE_SCHEDULER=true

# --- Database ---
# SQLite by default. For Postgres use e.g.:
#   postgresql+psycopg2://user:pass@localhost:5432/trading
DATABASE_URL=sqlite:///./trading_analytics.db

# --- Analytics thresholds (tunable, no code changes needed) ---
PCR_BULL_EXTREME=1.30
PCR_BEAR_EXTREME=0.70
RVOL_SPIKE=1.50
PINNING_DISTANCE_PCT=0.25

# --- Data source ---
# If true, the app seeds a synthetic intraday session instead of calling Upstox.
# Use this to launch the UI before your live token is wired.
USE_SYNTHETIC_DATA=true
